# Offline Justice Sync Configuration
# Copy this file to .env and fill in the values

# Remote sync server URL
SYNC_SERVER_URL=https://api.justice-os.org/sync

# Sync API key
SYNC_API_KEY=your-sync-api-key

# Twilio credentials for SMS fallback
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Local database path (for SQLite mode)
LOCAL_DB_PATH=./data/justice-local.db

# Sync interval in milliseconds (when online)
SYNC_INTERVAL_MS=30000

# Maximum retry attempts for failed syncs
MAX_RETRY_ATTEMPTS=5

# Bandwidth optimization level (low, medium, high)
BANDWIDTH_MODE=medium

# Enable SMS fallback
SMS_FALLBACK_ENABLED=true

# Connection quality check interval (ms)
CONNECTION_CHECK_INTERVAL_MS=5000

# Logging level
LOG_LEVEL=info
