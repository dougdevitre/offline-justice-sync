{
  "name": "@justice-os/offline-sync",
  "version": "0.1.0",
  "description": "Local-first database that works offline, syncs when connection returns, and falls back to SMS for critical communications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "justice",
    "offline-first",
    "local-first",
    "sync",
    "crdt",
    "indexeddb",
    "sqlite",
    "sms",
    "legal-tech"
  ],
  "author": "Justice OS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougdevitre/offline-justice-sync.git"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "idb": "^7.1.0",
    "pako": "^2.1.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/pako": "^2.0.0",
    "@types/react": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.50.0",
    "fake-indexeddb": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
